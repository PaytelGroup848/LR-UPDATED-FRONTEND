ENVIRONMENT=production

MONGODB_URL=mongodb://user:password@host:27017/?authSource=admin
MONGODB_DATABASE=lr_platform
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000

SECRET_KEY=replace-with-a-long-random-secret
CREDENTIAL_ENCRYPTION_KEY=replace-with-a-different-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

FRONTEND_URL=https://portal.example.com
CORS_ORIGINS=https://portal.example.com,https://admin.example.com
SOCKETIO_CORS_ORIGINS=https://portal.example.com,https://admin.example.com
PORTAL_HOME_URL=/portal

GUACAMOLE_URL=http://guacamole:8080/guacamole
GUACAMOLE_PUBLIC_URL=https://remote.example.com/guacamole
GUACAMOLE_USER=replace-with-guacamole-admin-user
GUACAMOLE_PASSWORD=replace-with-guacamole-admin-password
GUACAMOLE_DATA_SOURCE=mysql

RDP_PRECHECK_ENABLED=true
FILE_TRANSFER_ROOT=
FILE_TRANSFER_MAX_UPLOAD_BYTES=100000000
FILE_TRANSFER_MAX_READ_BYTES=1000000

API_GATEWAY_PORT=8000

LR_SUPER_ADMIN_USERNAME=replace-admin-username
LR_SUPER_ADMIN_EMAIL=admin@example.com
LR_SUPER_ADMIN_PASSWORD=replace-admin-password
